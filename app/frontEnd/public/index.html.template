                    </button>
                </nav>

                <!-- Content Panel -->
                <div class="content-panel">
                    <div class="tab-panel" data-tab="dashboard">
<!--#include views/tab-dashboard.html -->
                    </div>
                    <div class="tab-panel" data-tab="controls" style="display:none">
<!--#include views/tab-controls.html -->
                    </div>
                    <div class="tab-panel" data-tab="network" style="display:none">
<!--#include views/tab-network.html -->
                    </div>
                </div>
            </div>

            <!-- Modals (always in DOM) -->
<!--#include views/modals.html -->
        </div>
